#    mercadopago.com → Seu negócio → Configurações → Credenciais de produção
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx

# 2) Origem do seu site (sem barra no final) — pra liberar o CORS:
FRONTEND_ORIGIN=https://muhehehe123514-ux.github.io

# 3) URL pública DESTE backend no Render (sem barra no final):
PUBLIC_URL=https://pulsarads-backend.onrender.com
